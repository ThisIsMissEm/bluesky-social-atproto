{
  "name": "@atproto/pds-entryway-example",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Reference implementation of an atproto entryway server for Personal Data Server (PDS)",
  "keywords": [
    "atproto",
    "pds"
  ],
  "homepage": "https://atproto.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bluesky-social/atproto",
    "directory": "packages/pds-entryway-example"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18.7.0"
  },
  "scripts": {
    "prepare": "[ \"$npm_config_production\" = true ] || puppeteer browsers install chrome",
    "codegen": "lex gen-server --yes ./src/lexicon ../../lexicons/com/atproto/server/createAccount.json ../../lexicons/com/atproto/server/createSession.json ../../lexicons/com/atproto/server/getSession.json ../../lexicons/com/atproto/identity/updateHandle.json",
    "build": "tsc --build tsconfig.build.json",
    "test": "../dev-infra/with-test-redis-and-db.sh jest",
    "migration:create": "ts-node ./bin/migration-create.ts"
  },
  "dependencies": {
    "@atproto-labs/xrpc-utils": "workspace:*",
    "@atproto/api": "workspace:^",
    "@atproto/aws": "workspace:^",
    "@atproto/common": "workspace:^",
    "@atproto/crypto": "workspace:^",
    "@atproto/identity": "workspace:^",
    "@atproto/lexicon": "workspace:^",
    "@atproto/pds": "workspace:*",
    "@atproto/oauth-scopes": "workspace:^",
    "@atproto/syntax": "workspace:*",
    "@atproto/xrpc": "workspace:^",
    "@atproto/xrpc-server": "workspace:^",
    "@did-plc/lib": "^0.0.4",
    "@hapi/address": "^5.1.1",
    "cors": "^2.8.5",
    "better-sqlite3": "^10.0.0",
    "express": "^4.17.2",
    "express-async-errors": "^3.1.1",
    "http-terminator": "^3.2.0",
    "jose": "^5.0.1",
    "multiformats": "^9.9.0",
    "pino": "^8.21.0",
    "pino-http": "^8.2.1",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@atproto/api": "workspace:^",
    "@atproto/bsky": "workspace:^",
    "@atproto/lex-cli": "workspace:^",
    "@did-plc/server": "^0.0.1",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/express-serve-static-core": "^4.17.36",
    "@types/nodemailer": "^6.4.6",
    "@types/qs": "^6.9.7",
    "esbuild": "^0.14.48",
    "esbuild-plugin-handlebars": "^1.0.3",
    "get-port": "^6.1.2",
    "jest": "^28.1.2",
    "puppeteer": "^23.5.2",
    "ts-node": "^10.8.2",
    "typescript": "^5.6.3",
    "ws": "^8.12.0"
  }
